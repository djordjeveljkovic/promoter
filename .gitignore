##############################################################################
# Environment / secrets
##############################################################################
/.env
/.env.backup
/.env.production
/.env.local
/.env.*.local

##############################################################################
# Composer / PHP
##############################################################################
/vendor/
composer.phar
/.phpunit.cache/
/.phpunit.result.cache
/.phpactor.json

##############################################################################
# Node / Vite / front-end build assets
##############################################################################
/node_modules/
/public/build/
/public/hot
/package-lock.json
/yarn.lock
/npm-debug.log
/yarn-error.log
/bun.lock

##############################################################################
# Laravel storage — runtime, caches, logs, user uploads
##############################################################################
# Everything inside storage except framework defaults
/storage/*.key
/storage/pail/
/storage/logs/*
!/storage/logs/.gitignore
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/debugbar/*
/storage/app/private/*
!/storage/app/private/.gitignore
# User-uploaded files (the real source behind /public/storage)
/storage/app/public/*
!/storage/app/public/.gitignore

##############################################################################
# Public storage symlink + uploaded media
##############################################################################
# `php artisan storage:link` creates /public/storage -> /storage/app/public
# Ignore the symlink and any files that may exist there
/public/storage/
!/public/storage/.gitignore

# Uploaded images / generated assets served directly from public/
/public/img/*
!/public/img/.gitignore
!/public/img/.gitkeep

##############################################################################
# IDEs / editors / OS junk
##############################################################################
/.idea/
/.vscode/
/.fleet/
/.nova/
/.zed/
/.DS_Store
/Thumbs.db
desktop.ini
*.swp
*.swo
*.sublime-project
*.sublime-workspace

##############################################################################
# Laravel-specific helpers
##############################################################################
/Homestead.json
/Homestead.yaml
/auth.json
npm-debug.log
yarn-error.log
.server.php
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php
.phpunit.cache

##############################################################################
# Temp / local-only
##############################################################################
/storage/temp_zips/*
!/storage/temp_zips/.gitignore
